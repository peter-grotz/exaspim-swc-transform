#!/usr/bin/env bash
set -euo pipefail

# Mode handling for dual-wired pipelines:
# - modern mode: run this capsule
# - legacy mode: no-op (successful exit)
MODE="${transform_mode:-${TRANSFORM_MODE:-modern}}"
REMAINING_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --transform_mode)
      [[ $# -ge 2 ]] || { echo "ERROR: --transform_mode requires a value" >&2; exit 2; }
      MODE="$2"
      shift 2
      ;;
    --transform_mode=*)
      MODE="${1#*=}"
      shift
      ;;
    --transform-mode)
      [[ $# -ge 2 ]] || { echo "ERROR: --transform-mode requires a value" >&2; exit 2; }
      MODE="$2"
      shift 2
      ;;
    --transform-mode=*)
      MODE="${1#*=}"
      shift
      ;;
    --mode)
      [[ $# -ge 2 ]] || { echo "ERROR: --mode requires a value" >&2; exit 2; }
      MODE="$2"
      shift 2
      ;;
    --mode=*)
      MODE="${1#*=}"
      shift
      ;;
    *)
      REMAINING_ARGS+=("$1")
      shift
      ;;
  esac
done

MODE="$(printf '%s' "${MODE}" | tr '[:upper:]' '[:lower:]')"
case "${MODE}" in
  ""|modern)
    ;;
  legacy)
    echo "transform_mode=legacy -> modern capsule no-op."
    exit 0
    ;;
  *)
    echo "ERROR: Unsupported transform mode '${MODE}'. Use 'modern' or 'legacy'." >&2
    exit 2
    ;;
esac

TRANSFORM_DIR_ARG="${REMAINING_ARGS[0]-${transform_dir:-${TRANSFORM_DIR:-}}}"
MANUAL_DF_PATH_ARG="${REMAINING_ARGS[1]-${manual_df_path:-${MANUAL_DF_PATH:-}}}"

# Use local source checkout directly; dependencies are installed in image build.
export PYTHONPATH="${PWD}/src:${PYTHONPATH:-}"

python run.py \
  --swc-dir "${swc_dir:-${SWC_DIR:-/data/swc_refinement/final-world}}" \
  --transform-dir "${TRANSFORM_DIR_ARG}" \
  --manual-df-path "${MANUAL_DF_PATH_ARG}" \
  --output-root "${output_root:-${OUTPUT_ROOT:-/results/exaspim_swc_transform}}" \
  --naming-style "${naming_style:-${NAMING_STYLE:-preserve}}"
