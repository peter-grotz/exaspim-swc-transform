#!/usr/bin/env bash
set -euo pipefail

PYTHON_BIN="${PYTHON_BIN:-python3}"
if ! command -v "${PYTHON_BIN}" >/dev/null 2>&1; then
  PYTHON_BIN="python"
fi

clean_token() {
  local value="${1:-}"
  local first_char=""
  local last_char=""

  if [[ "${value}" == "''" || "${value}" == "\"\"" ]]; then
    printf ''
    return 0
  fi

  if [[ ${#value} -ge 2 ]]; then
    first_char="${value:0:1}"
    last_char="${value: -1}"
    if [[ "${first_char}" == "${last_char}" && ( "${first_char}" == "'" || "${first_char}" == '"' ) ]]; then
      value="${value:1:${#value}-2}"
    fi
  fi

  printf '%s' "${value}"
}

copy_first_dir() {
  local destination="$1"
  shift
  local source
  for source in "$@"; do
    if [[ -d "${source}" ]]; then
      mkdir -p "${destination}"
      cp -R "${source}/." "${destination}/"
      return 0
    fi
  done
  return 1
}

copy_first_nested_dir() {
  local destination="$1"
  local relative_path="$2"
  local base="${3:-/data}"
  local child
  if [[ ! -d "${base}" ]]; then
    return 1
  fi
  for child in "${base}"/*; do
    [[ -d "${child}" ]] || continue
    if [[ -d "${child}/${relative_path}" ]]; then
      mkdir -p "${destination}"
      cp -R "${child}/${relative_path}/." "${destination}/"
      return 0
    fi
  done
  return 1
}

# Mode handling for dual-wired pipelines:
# - modern mode: run this capsule
# - legacy mode: no-op (successful exit)
MODE="${transform_mode:-${TRANSFORM_MODE:-modern}}"
MODE_EXPLICIT=0
if [[ -n "${transform_mode:-}" || -n "${TRANSFORM_MODE:-}" ]]; then
  MODE_EXPLICIT=1
fi
REMAINING_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --transform_mode)
      [[ $# -ge 2 ]] || { echo "ERROR: --transform_mode requires a value" >&2; exit 2; }
      MODE="$2"
      MODE_EXPLICIT=1
      shift 2
      ;;
    --transform_mode=*)
      MODE="${1#*=}"
      MODE_EXPLICIT=1
      shift
      ;;
    --transform-mode)
      [[ $# -ge 2 ]] || { echo "ERROR: --transform-mode requires a value" >&2; exit 2; }
      MODE="$2"
      MODE_EXPLICIT=1
      shift 2
      ;;
    --transform-mode=*)
      MODE="${1#*=}"
      MODE_EXPLICIT=1
      shift
      ;;
    --mode)
      [[ $# -ge 2 ]] || { echo "ERROR: --mode requires a value" >&2; exit 2; }
      MODE="$2"
      MODE_EXPLICIT=1
      shift 2
      ;;
    --mode=*)
      MODE="${1#*=}"
      MODE_EXPLICIT=1
      shift
      ;;
    transform_mode|TRANSFORM_MODE|mode|MODE)
      [[ $# -ge 2 ]] || { echo "ERROR: $1 requires a value" >&2; exit 2; }
      MODE="$2"
      MODE_EXPLICIT=1
      shift 2
      ;;
    transform_mode=*|TRANSFORM_MODE=*|mode=*|MODE=*)
      MODE="${1#*=}"
      MODE_EXPLICIT=1
      shift
      ;;
    *)
      REMAINING_ARGS+=("$1")
      shift
      ;;
  esac
done

# App-panel positional compatibility:
# if mode was not set via flags/env, allow a trailing plain token "modern|legacy".
if [[ "${MODE_EXPLICIT}" -eq 0 && ${#REMAINING_ARGS[@]} -gt 0 ]]; then
  LAST_INDEX=$(( ${#REMAINING_ARGS[@]} - 1 ))
  LAST_TOKEN="${REMAINING_ARGS[$LAST_INDEX]}"
  LAST_TOKEN_LC="$(printf '%s' "${LAST_TOKEN}" | tr '[:upper:]' '[:lower:]')"
  case "${LAST_TOKEN_LC}" in
    modern|legacy)
      MODE="${LAST_TOKEN_LC}"
      unset 'REMAINING_ARGS[$LAST_INDEX]'
      REMAINING_ARGS=("${REMAINING_ARGS[@]}")
      ;;
  esac
fi

MODE="$(printf '%s' "${MODE}" | tr '[:upper:]' '[:lower:]')"
case "${MODE}" in
  ""|modern)
    ;;
  legacy)
    copy_first_dir /results/dispatch /data/dispatch /data/output/dispatch >/dev/null 2>&1 || true
    if [[ ! -d /results/dispatch ]]; then
      copy_first_nested_dir /results/dispatch dispatch /data >/dev/null 2>&1 || true
      copy_first_nested_dir /results/dispatch dispatch /data/output >/dev/null 2>&1 || true
    fi
    copy_first_dir /results/refinement \
      /data/refinement \
      /data/swc_refinement \
      /data/output/refinement \
      /data/output/swc_refinement \
      >/dev/null 2>&1 || true
    if [[ ! -d /results/refinement ]]; then
      copy_first_nested_dir /results/refinement refinement /data >/dev/null 2>&1 || true
      copy_first_nested_dir /results/refinement swc_refinement /data >/dev/null 2>&1 || true
      copy_first_nested_dir /results/refinement refinement /data/output >/dev/null 2>&1 || true
      copy_first_nested_dir /results/refinement swc_refinement /data/output >/dev/null 2>&1 || true
    fi
    echo "transform_mode=legacy -> modern capsule passthrough."
    exit 0
    ;;
  *)
    echo "ERROR: Unsupported transform mode '${MODE}'. Use 'modern' or 'legacy'." >&2
    exit 2
    ;;
esac

SWC_DIR_ARG="$(clean_token "${swc_dir:-${SWC_DIR:-/data/refinement/final-world}}")"
TRANSFORM_DIR_ARG="$(clean_token "${REMAINING_ARGS[0]-${transform_dir:-${TRANSFORM_DIR:-}}}")"
MANUAL_DF_PATH_ARG="$(clean_token "${REMAINING_ARGS[1]-${manual_df_path:-${MANUAL_DF_PATH:-}}}")"
ACQUISITION_FILE_PATH_ARG="$(clean_token "${REMAINING_ARGS[2]-${acquisition_file_path:-${ACQUISITION_FILE_PATH:-}}}")"
LOADED_ZARR_IMAGE_PATH_ARG="$(clean_token "${REMAINING_ARGS[3]-${loaded_zarr_image_path:-${LOADED_ZARR_IMAGE_PATH:-}}}")"
RESAMPLED_ZARR_IMAGE_PATH_ARG="$(clean_token "${REMAINING_ARGS[4]-${resampled_zarr_image_path:-${RESAMPLED_ZARR_IMAGE_PATH:-}}}")"
SAMPLE_TO_EXASPIM_AFFINE_PATH_ARG="$(clean_token "${REMAINING_ARGS[5]-${sample_to_exaspim_affine_path:-${SAMPLE_TO_EXASPIM_AFFINE_PATH:-}}}")"
SAMPLE_TO_EXASPIM_INVERSE_WARP_PATH_ARG="$(clean_token "${REMAINING_ARGS[6]-${sample_to_exaspim_inverse_warp_path:-${SAMPLE_TO_EXASPIM_INVERSE_WARP_PATH:-}}}")"

# Use local source checkout directly; dependencies are installed in image build.
export PYTHONPATH="${PWD}/src:${PYTHONPATH:-}"

RUN_ARGS=(
  run.py
  --swc-dir "${SWC_DIR_ARG}"
  --transform-dir "${TRANSFORM_DIR_ARG}"
  --manual-df-path "${MANUAL_DF_PATH_ARG}"
)

if [[ -n "${ACQUISITION_FILE_PATH_ARG}" ]]; then
  RUN_ARGS+=(--acquisition-file-path "${ACQUISITION_FILE_PATH_ARG}")
fi
if [[ -n "${LOADED_ZARR_IMAGE_PATH_ARG}" ]]; then
  RUN_ARGS+=(--loaded-zarr-image-path "${LOADED_ZARR_IMAGE_PATH_ARG}")
fi
if [[ -n "${RESAMPLED_ZARR_IMAGE_PATH_ARG}" ]]; then
  RUN_ARGS+=(--resampled-zarr-image-path "${RESAMPLED_ZARR_IMAGE_PATH_ARG}")
fi
if [[ -n "${SAMPLE_TO_EXASPIM_AFFINE_PATH_ARG}" ]]; then
  RUN_ARGS+=(--sample-to-exaspim-affine-path "${SAMPLE_TO_EXASPIM_AFFINE_PATH_ARG}")
fi
if [[ -n "${SAMPLE_TO_EXASPIM_INVERSE_WARP_PATH_ARG}" ]]; then
  RUN_ARGS+=(--sample-to-exaspim-inverse-warp-path "${SAMPLE_TO_EXASPIM_INVERSE_WARP_PATH_ARG}")
fi

"${PYTHON_BIN}" "${RUN_ARGS[@]}"
